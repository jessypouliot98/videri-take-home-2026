{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": [
        "generated/**",
        ".next/**",
        "dist/**"
      ]
    },
    "start:dev": {
      "dependsOn": ["^generate"],
      "persistent": true,
      "cache": false
    }
  }
}
